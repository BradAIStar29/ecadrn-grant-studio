rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 0. Global Safety Net ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helper Functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isEcadrnMember() {
      return isSignedIn() &&
             request.auth.token.email != null &&
             request.auth.token.email.matches('.*@ecadrn\\.org');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPersonalOrgMember(orgId) {
      return isOwner(orgId);
    }

    function isSharedOrgMember(orgId) {
      return orgId == 'ecadrn-shared' && isEcadrnMember();
    }

    function isOrgMember(orgId) {
      return isPersonalOrgMember(orgId) || isSharedOrgMember(orgId);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ── Entity Validators ─────────────────────────────────────────────────────
    // CREATE validators require all mandatory fields (full document).
    // UPDATE validators only require updatedAt + validate fields that ARE present.
    // This allows setDoc({merge: true} partial updates without being rejected.

    function isValidOrganizationCreate(data) {
      return data.keys().hasAll(['name', 'profileText', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.profileText is string && data.profileText.size() <= 10000 &&
             data.updatedAt is string;
    }

    function isValidOrganizationUpdate(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.get('name', '') is string && data.get('name', '').size() <= 200 &&
             data.get('profileText', '') is string && data.get('profileText', '').size() <= 10000 &&
             data.updatedAt is string;
    }

    function isValidFunder(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.get('funderName', '') is string && data.get('funderName', '').size() <= 200 &&
             data.get('website', '') is string && data.get('website', '').size() <= 256 &&
             data.get('contactName', '') is string && data.get('contactName', '').size() <= 200 &&
             data.get('relationshipStage', '') is string &&
             data.updatedAt is string;
    }

    function isValidGrantCreate(data) {
      return data.keys().hasAll(['title', 'updatedAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.updatedAt is string;
    }

    function isValidGrantUpdate(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.get('title', '') is string && data.get('title', '').size() <= 200 &&
             data.updatedAt is string;
    }

    function isValidProposalCreate(data) {
      return data.keys().hasAll(['title', 'status', 'updatedAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['draft', 'review', 'submitted', 'awarded', 'declined'] &&
             data.updatedAt is string;
    }

    function isValidProposalUpdate(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.get('title', '') is string && data.get('title', '').size() <= 200 &&
             data.get('status', 'draft') in ['draft', 'review', 'submitted', 'awarded', 'declined'] &&
             data.updatedAt is string;
    }

    function isValidTemplateCreate(data) {
      return data.keys().hasAll(['name', 'sections', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.sections is list &&
             data.createdAt is string;
    }

    function isValidTemplateUpdate(data) {
      return data.get('name', '') is string && data.get('name', '').size() <= 200 &&
             (data.keys().has('sections') ? data.sections is list : true);
    }

    function isValidVoiceProfileCreate(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.createdAt is string;
    }

    function isValidVoiceProfileUpdate(data) {
      return data.get('name', '') is string && data.get('name', '').size() <= 200 &&
             data.get('createdAt', '') is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'message', 'read', 'timestamp']) &&
             data.userId == request.auth.uid &&
             (data.type == 'comment' || data.type == 'assignment' || data.type == 'mention' ||
              data.type == 'autopilot_submission' || data.type == 'deadline_reminder' ||
              data.type == 'error' || data.type == 'manual_save' || data.type == 'grant' ||
              data.type == 'proposal' || data.type == 'spring') &&
             data.message is string && data.message.size() <= 1000 &&
             data.read is bool &&
             data.timestamp is string;
    }

    // ── Organizations ─────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow get:    if isOrgMember(orgId) && isValidId(orgId);
      allow list:   if isSignedIn() && (isOwner(request.auth.uid) || isEcadrnMember());
      allow create: if isOrgMember(orgId) && isValidOrganizationCreate(incoming());
      allow update: if isOrgMember(orgId) && isValidOrganizationUpdate(incoming()) &&
                       incoming().diff(existing()).affectedKeys()
                         .hasOnly(['name', 'profileText', 'voiceProfile', 'updatedAt', 'members',
                                   'focusAreas', 'geographicFocus', 'typicalGrantMin', 'typicalGrantMax',
                                   'discoveryKeywords']);
      allow delete: if false;

      // ── Funders ─────────────────────────────────────────────────────────────
      match /funders/{funderId} {
        allow get:    if isOrgMember(orgId) && isValidId(funderId);
        allow list:   if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidId(funderId) && isValidFunder(incoming());
        allow update: if isOrgMember(orgId) && isValidId(funderId) && isValidFunder(incoming()) &&
                         incoming().diff(existing()).affectedKeys()
                           .hasOnly(['funderName', 'website', 'contactName', 'relationshipStage',
                                     'notes', 'intelligence', 'lastAnalysisAt', 'updatedAt',
                                     'tags', 'source']);
        allow delete: if isOrgMember(orgId) && isValidId(funderId);
      }

      // ── Voice Profiles ───────────────────────────────────────────────────────
      match /voiceProfiles/{profileId} {
        allow list:   if isOrgMember(orgId);
        allow get:    if isOrgMember(orgId) && isValidId(profileId);
        allow create: if isOrgMember(orgId) && isValidId(profileId) && isValidVoiceProfileCreate(incoming());
        allow update: if isOrgMember(orgId) && isValidId(profileId) && isValidVoiceProfileUpdate(incoming());
        allow delete: if isOrgMember(orgId) && isValidId(profileId);
      }

      // ── Templates ────────────────────────────────────────────────────────────
      match /templates/{templateId} {
        allow list:   if isOrgMember(orgId);
        allow get:    if isOrgMember(orgId) && isValidId(templateId);
        allow create: if isOrgMember(orgId) && isValidId(templateId) && isValidTemplateCreate(incoming());
        allow update: if isOrgMember(orgId) && isValidId(templateId) && isValidTemplateUpdate(incoming());
        allow delete: if isOrgMember(orgId) && isValidId(templateId);
      }

      // ── Grants ───────────────────────────────────────────────────────────────
      match /grants/{grantId} {
        allow get:    if isOrgMember(orgId) && isValidId(grantId);
        allow list:   if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidId(grantId) && isValidGrantCreate(incoming());
        allow update: if isOrgMember(orgId) && isValidId(grantId) && isValidGrantUpdate(incoming());
        allow delete: if isOrgMember(orgId) && isValidId(grantId);
      }

      // ── Proposals ────────────────────────────────────────────────────────────
      match /proposals/{proposalId} {
        allow get:    if isOrgMember(orgId) && isValidId(proposalId);
        allow list:   if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidId(proposalId) && isValidProposalCreate(incoming());
        allow update: if isOrgMember(orgId) && isValidId(proposalId) && isValidProposalUpdate(incoming()) &&
                         incoming().diff(existing()).affectedKeys()
                           .hasOnly(['title', 'status', 'sections', 'updatedAt',
                                     'reviewResults', 'collaborators', 'budget',
                                     'createdBy', 'lastEditedBy', 'funder', 'assignee',
                                     'description', 'source', 'autopilot', 'matchScore',
                                     'createdAt']);
        allow delete: if isOrgMember(orgId) && isValidId(proposalId);

        match /comments/{commentId} {
          allow list:   if isOrgMember(orgId);
          allow get:    if isOrgMember(orgId) && isValidId(commentId);
          allow create: if isOrgMember(orgId) && isValidId(commentId);
          allow update: if isOrgMember(orgId) && isValidId(commentId) &&
                           resource.data.userId == request.auth.uid;
          allow delete: if isOrgMember(orgId) && isValidId(commentId) &&
                           resource.data.userId == request.auth.uid;
        }

        match /presence/{userId} {
          allow list:   if isOrgMember(orgId);
          allow get:    if isOrgMember(orgId) && isValidId(userId);
          allow write:  if isOrgMember(orgId) && isOwner(userId) && isValidId(userId);
        }

        match /versions/{versionId} {
          allow list:   if isOrgMember(orgId);
          allow get:    if isOrgMember(orgId) && isValidId(versionId);
          allow create: if isOrgMember(orgId) && isValidId(versionId);
          allow update: if false;
          allow delete: if false;
        }
      }

      // ── Notifications ───────────────────────────────────────────────────────
      match /notifications/{notificationId} {
        allow get:    if isOrgMember(orgId) && isValidId(notificationId) &&
                         resource.data.userId == request.auth.uid;
        allow list:   if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidNotification(incoming());
        allow update: if isOrgMember(orgId) && isValidId(notificationId) &&
                         resource.data.userId == request.auth.uid &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOrgMember(orgId) && isValidId(notificationId) &&
                         resource.data.userId == request.auth.uid;
      }

      // ── Saved Searches ──────────────────────────────────────────────────────
      match /savedSearches/{searchId} {
        allow get:    if isOrgMember(orgId) && isValidId(searchId);
        allow list:   if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidId(searchId);
        allow update: if isOrgMember(orgId) && isValidId(searchId);
        allow delete: if isOrgMember(orgId) && isValidId(searchId);
      }
    }
  }
}
