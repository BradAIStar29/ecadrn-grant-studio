{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "echo 'API only — no frontend build needed'",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
