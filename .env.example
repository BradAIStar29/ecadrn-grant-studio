# Copy this file to .env.local for local development

# Gemini API Key (for local dev only — in production, set this in Vercel)
GEMINI_API_KEY="your-gemini-api-key-here"

# For local dev — leave empty (Express server handles /api routes)
VITE_API_BASE_URL=

# For GitHub Pages build — set to /your-repo-name/
VITE_BASE_PATH=/ecadrn-grant-studio/
